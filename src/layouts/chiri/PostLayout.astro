---
import "@/styles/global.css";
import "@/styles/chiri/post.css";
import BaseLayout from "@/layouts/chiri/BaseLayout.astro";

const { title, pubDate } = Astro.props;

const dateStr = new Date(pubDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={title}>
  <div class="max-w-2xl mx-auto py-6 animate-fade-in-up">
    <!-- Back button -->
    <a href="/blog" class="text-xs font-mono text-zinc-400 hover:text-white transition-colors duration-200 uppercase tracking-wider mb-8 block">
      ← Back to blog
    </a>

    <header class="mb-8 border-b border-zinc-900 pb-6">
      <h1 class="text-3xl font-extrabold text-white tracking-tight font-sans mb-3">
        {title}
      </h1>
      <div class="text-xs font-mono text-zinc-500">
        Published on {dateStr}
      </div>
    </header>

    <div class="prose max-w-none text-zinc-300 font-sans leading-relaxed">
      <slot />
    </div>
  </div>
</BaseLayout>
