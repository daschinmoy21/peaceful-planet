---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header";
import Skills from "../components/Skills";
import Projects from "../components/Projects";
import Experience from "../components/Experience";
import OpenSource from "../components/OpenSource";
import Contact from "../components/Contact";
import HomePosts from "../components/HomePosts";
import { getSortedFilteredPosts } from "@/utils/chiri/draft";
import { fetchGitHubPRs } from "@/utils/github";

const posts = await getSortedFilteredPosts();
const prs = await fetchGitHubPRs().catch(() => []);
---

<Layout>
	<Header client:load />

	<Skills client:load />
	<OpenSource client:load prs={prs} limit={6} />
	<Experience client:visible />
	<Projects client:visible limit={3} />
	<HomePosts posts={posts.slice(0, 3)} client:visible />
	<Contact client:visible />
</Layout>
