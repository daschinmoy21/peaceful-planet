---
import Layout from "../layouts/Layout.astro";
import OpenSource from "../components/OpenSource.astro";
import { fetchGitHubPRs } from "@/utils/github";

const prs = await fetchGitHubPRs().catch(() => []);
---

<Layout>
  <div class="py-6">
    <OpenSource prs={prs} graphPosition="top" />
  </div>
</Layout>
