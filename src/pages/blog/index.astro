---
import Layout from '@/layouts/Layout.astro'
import { getSortedFilteredPosts } from '@/utils/chiri/draft'

const posts = await getSortedFilteredPosts()
---

<Layout>
  <div class="py-6 animate-fade-in-up">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-xs font-mono font-bold tracking-widest text-zinc-500 uppercase">All Blog Posts</h1>
      <a href="/rss.xml" target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity shrink-0">
        <img src="/rss-button.gif" width="88" height="31" alt="RSS Feed" class="rounded-sm border border-zinc-200 dark:border-zinc-900" />
      </a>
    </div>

    <div class="flex flex-col gap-6">
      {posts.map((post) => (
        <div class="flex flex-col gap-1.5">
          <div class="flex items-baseline justify-between gap-4">
            <a
              href={`/blog/${post.id}`}
              class="text-base font-semibold text-zinc-900 dark:text-zinc-100 hover:text-blue-500 dark:hover:text-white transition-colors font-sans tracking-tight"
            >
              {post.data.title}
            </a>
            <span class="text-xs font-mono text-zinc-500 shrink-0 font-medium">
              {post.data.pubDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </span>
          </div>
          {post.data.description && (
            <p class="text-sm text-zinc-400 font-sans leading-relaxed">
              {post.data.description}
            </p>
          )}
          <a
            href={`/blog/${post.id}`}
            class="text-xs font-mono text-zinc-500 hover:text-zinc-950 dark:hover:text-white transition-colors duration-200 w-fit flex items-center gap-1 mt-0.5 group"
          >
            <span class="text-zinc-700 transition-colors group-hover:text-zinc-950 dark:group-hover:text-zinc-300">→</span> read post
          </a>
        </div>
      ))}
    </div>
  </div>
</Layout>
