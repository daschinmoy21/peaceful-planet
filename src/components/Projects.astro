---
interface Props {
  limit?: number;
}

const { limit } = Astro.props as Props;

const projects = [
  {
    title: "Russel",
    description: "A cloud-native orchestrator that spawns ephemeral microVMs in milliseconds via Cloud Hypervisor. Combines VM isolation with container-like speed using QCOW2 and hotplugging.",
    status: "currently working on",
    statusColor: "text-emerald-500",
    linkText: "github.com/daschinmoy21/russel",
    link: "https://github.com/daschinmoy21/russel",
    image: "/wip.jpg",
  },
  {
    title: "Logia",
    description: "A modern notes app that transcribes lectures, featuring an in-built canvas and offline-first AI processing capabilities.",
    linkText: "github.com/daschinmoy21/logia",
    link: "https://www.github.com/daschinmoy21/logia",
    image: "/logia.webp",
  },
  {
    title: "Lightspeed",
    description: "P2P local file sharing utilizing TCP and QUIC for maximum throughput, engineered to outperform existing local transfer solutions.",
    linkText: "github.com/daschinmoy21/lightspeed",
    link: "https://github.com/daschinmoy21/lightspeed",
    image: "/lightspeed.png",
  },
  {
    title: "LMS Discord Bot",
    description: "A Discord bot that automatically monitors college LMS portals to notify users about assignment, lab, and quiz updates.",
    linkText: "github.com/daschinmoy21/LmsBot",
    link: "https://github.com/daschinmoy21/LmsBot",
    image: "/discord2.png",
  },
  {
    title: "Trello Clone",
    description: "A fullstack Trello-like application with role-based access control, Kanban boards, real-time board updates, and integrated board chat.",
    linkText: "github.com/daschinmoy21/trello",
    link: "https://github.com/daschinmoy21/trello",
    image: "/trello.png",
  },
  {
    title: "BlockShare",
    description: "A decentralized file-sharing application combining blockchain technology with IPFS for secure, distributed file ownership tracking.",
    linkText: "github.com/daschinmoy21/BlockShare",
    link: "https://github.com/daschinmoy21/BlockShare",
    image: "/web3-1.png",
  },
  {
    title: "CipherPress",
    description: "A censorship-resistant decentralized news platform where articles are hosted on IPFS and indexed on-chain.",
    linkText: "github.com/daschinmoy21/CipherPress",
    link: "https://github.com/daschinmoy21/CipherPress",
    image: "/web3-1.png",
  }
];

const visibleProjects = limit ? projects.slice(0, limit) : projects;
---

<div class="max-w-2xl mx-auto py-6">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-xs font-mono font-bold tracking-widest text-zinc-500 uppercase">Projects</h2>
    {limit && (
      <a href="/projects" class="text-xs font-mono text-zinc-400 hover:text-zinc-950 dark:hover:text-white transition-colors duration-200 uppercase tracking-wider">
        View all →
      </a>
    )}
  </div>

  <div class="flex flex-col gap-8">
    {visibleProjects.map((project) => (
      <div class="flex flex-col sm:flex-row gap-5 items-start animate-fade-in-up">
        {project.image && (
          <a 
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full sm:w-28 aspect-video rounded-sm overflow-hidden border border-zinc-200 dark:border-zinc-900 bg-zinc-900 shrink-0 block"
          >
            <img 
              src={project.image} 
              alt={project.title} 
              class="w-full h-full object-cover transition-transform duration-300 hover:scale-105" 
            />
          </a>
        )}
        <div class="flex-1 min-w-0 flex flex-col gap-1.5">
          <div class="flex items-center gap-2.5">
            <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 tracking-tight font-sans">
              {project.title}
            </h3>
            {project.status && (
              <span class={`text-[10px] font-mono font-medium uppercase tracking-wider ${project.statusColor || 'text-zinc-500'}`}>
                ● {project.status}
              </span>
            )}
          </div>
          <p class="text-sm text-zinc-400 font-sans leading-relaxed">
            {project.description}
          </p>
          <a 
            href={project.link} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="text-xs font-mono text-zinc-500 hover:text-zinc-950 dark:hover:text-white transition-colors duration-200 w-fit flex items-center gap-1 mt-0.5 group"
          >
            <span class="text-zinc-700 transition-colors group-hover:text-zinc-400 group-hover:dark:text-zinc-300">→</span> {project.linkText}
          </a>
        </div>
      </div>
    ))}
  </div>
</div>
