<script>
  const clock = document.getElementById("clock")!;
  const tick = () => {
    clock.textContent = new Date().toLocaleTimeString("en-US", {
      timeZone: "Asia/Kolkata",
      hour: "2-digit",
      minute: "2-digit",
      hour12: true,
    });
  };
  tick();
  setInterval(tick, 1000);
</script>
