<script>
  // Clock update
  const clock = document.getElementById("header-clock")!;
  const updateClock = () => {
    clock.textContent = new Date().toLocaleTimeString("en-US", {
      timeZone: "Asia/Kolkata",
      hour: "2-digit",
      minute: "2-digit",
      hour12: true,
    });
  };
  updateClock();
  setInterval(updateClock, 1000);
</script>
