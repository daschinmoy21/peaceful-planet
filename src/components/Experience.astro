---
const experiences = [
  {
    company: "Freelance",
    role: "Contract Developer",
    period: "2025 - Present",
    description: [
      "Designed, developed, and deployed a high-performance website for a non-governmental organization (NGO) using Astro and TypeScript",
      "Optimized build pipeline and static site generation, achieving 100/100 Lighthouse performance and accessibility scores",
      "Set up streamlined content editing workflows and integrated hosting, enabling non-technical staff to easily publish updates"
    ],
  },
];
---

<div class="max-w-2xl mx-auto py-6">
  <h2 class="text-xs font-mono font-bold tracking-widest text-zinc-500 uppercase mb-6">Experience</h2>

  <div class="flex flex-col gap-6">
    {experiences.map((exp) => (
      <div class="flex flex-col gap-2 animate-fade-in-up">
        <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
          <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-2">
            <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 tracking-tight font-sans">
              {exp.role}
            </h3>
            <span class="text-xs font-mono text-zinc-500">at {exp.company}</span>
          </div>
          <span class="text-xs font-mono text-zinc-400 shrink-0">{exp.period}</span>
        </div>
        
        <ul class="flex flex-col gap-1.5 font-mono text-xs text-zinc-400 mt-1 pl-1">
          {exp.description.map((item) => (
            <li class="flex items-start gap-2.5 leading-relaxed">
              <span class="text-zinc-600 shrink-0 select-none">→</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>
