---
const experiences = [
  {
    company: "Contract Developer",
    role: "Freelance",
    period: "2025 - Present",
    description: [
      "Built end-to-end websites for various clients using Astro, React, TS and handled deployment ensuring high uptime under traffic",
      "Designed and deployed a production website used by large user base",
      "Implemented backend APIs for registration, contact, content management",
    ],
  },
];
---

<div data-reveal class="max-w-4xl mx-auto px-4 py-8 text-zinc-300">
  <h1 class="text-3xl font-bold mb-8 ml-5 text-white w-fit">
    Experience
  </h1>

  <div class="space-y-6 ml-5">
    {experiences.map((exp, index) => (
      <div
        data-reveal
        data-reveal-delay={index * 100}
        class="relative pl-8 border-l border-zinc-700/50 hover:border-zinc-500 transition-colors group"
      >
        <div class="timeline-dot absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-zinc-700 ring-4 ring-zinc-900 group-hover:bg-blue-500 group-hover:shadow-[0_0_12px_rgba(59,130,246,0.5)] transition-all duration-300"></div>
        <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1">
          <h3 class="text-lg font-semibold text-zinc-100">
            {exp.role}
          </h3>
          <span class="text-sm font-mono text-white">{exp.period}</span>
        </div>
        <div class="text-md text-blue-400 mb-2">{exp.company}</div>
        <ul class="list-disc list-outside ml-4 space-y-1">
          {exp.description.map((item, i) => (
            <li class="text-zinc-400 text-sm leading-relaxed">{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>
