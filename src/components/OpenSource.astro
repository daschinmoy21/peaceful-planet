---
interface GHPR {
  id: string;
  title: string;
  state: "open" | "closed";
  html_url: string;
  created_at: string;
  closed_at: string | null;
  merged_at: string | null;
  number: number;
  repo: {
    name: string;
    full_name: string;
    html_url: string;
    stars: number;
  };
}

interface Props {
  prs: GHPR[];
  limit?: number;
  graphPosition?: "top" | "bottom";
}

const { prs, limit, graphPosition = "bottom" } = Astro.props as Props;
const visiblePRs = limit ? prs.slice(0, limit) : prs;
const hasMore = limit && prs.length > limit;

import { fetchGitHubContributionsTable } from "@/utils/github";
const contributionsHtml = await fetchGitHubContributionsTable().catch(() => "");
---

<div class="max-w-2xl mx-auto py-6">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-xs font-mono font-bold tracking-widest text-zinc-500 uppercase">Open Source</h2>
    {hasMore && (
      <a href="/oss" class="text-xs font-mono text-zinc-400 hover:text-white transition-colors duration-200 uppercase tracking-wider">
        View all →
      </a>
    )}
  </div>

  <!-- Contribution Chart (TOP) -->
  {graphPosition === "top" && contributionsHtml && (
    <div class="mb-8 border border-zinc-900 p-4 rounded-sm flex flex-col gap-3 font-mono github-calendar-card">
      <div class="text-[10px] text-zinc-500 uppercase tracking-widest">Contributions Graph</div>
      <div class="overflow-x-auto w-full github-calendar-wrapper">
        <Fragment set:html={contributionsHtml} />
      </div>
    </div>
  )}

  {prs.length === 0 && (
    <div class="text-xs font-mono text-zinc-600">
      No open source contributions found.
    </div>
  )}

  <div class="flex flex-col gap-5">
    {visiblePRs.map((pr) => {
      const merged = !!pr.merged_at;
      const open = pr.state === "open";
      const statusLabel = merged ? "merged" : open ? "open" : "closed";
      const statusColor = merged ? "text-purple-400" : open ? "text-emerald-500" : "text-rose-500";
      const date = new Date(pr.created_at).toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
      });
      
      return (
        <div class="flex flex-col gap-0.5 animate-fade-in-up">
          <div class="flex items-start justify-between gap-4">
            <a 
              href={pr.html_url} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="text-sm font-medium text-zinc-200 hover:text-white transition-colors font-sans tracking-tight"
            >
              {pr.title}
            </a>
            <span class={`text-[10px] font-mono font-medium uppercase tracking-wider shrink-0 mt-0.5 ${statusColor}`}>
              ● {statusLabel}
            </span>
          </div>
          <div class="flex flex-wrap items-center gap-3 text-xs font-mono text-zinc-500">
            <a 
              href={pr.repo.html_url} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="hover:text-zinc-400 transition-colors"
            >
              {pr.repo.full_name}
            </a>
            <span class="flex items-center gap-0.5"><span class="text-amber-400 font-sans">★</span>{pr.repo.stars}</span>
            <span>#{pr.number}</span>
            <span>{date}</span>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Contribution Chart (BOTTOM) -->
  {graphPosition === "bottom" && contributionsHtml && (
    <div class="mt-8 border border-zinc-900 p-4 rounded-sm flex flex-col gap-3 font-mono github-calendar-card">
      <div class="text-[10px] text-zinc-500 uppercase tracking-widest">Contributions Graph</div>
      <div class="overflow-x-auto w-full github-calendar-wrapper">
        <Fragment set:html={contributionsHtml} />
      </div>
    </div>
  )}
</div>
