---
<footer class="max-w-2xl mx-auto px-6 py-8 mt-12 border-t border-zinc-200 dark:border-zinc-900 flex flex-col sm:flex-row items-center justify-between gap-4">
  <div class="text-[10px] font-mono text-zinc-500 uppercase tracking-widest">
    © {new Date().getFullYear()} chinmoy
  </div>
  <div class="flex flex-wrap items-center gap-2 justify-center sm:justify-end">
    <img 
      src="/buttons/nixos.gif" 
      width="88" 
      height="31" 
      alt="NixOS" 
      loading="lazy"
      decoding="async"
      class="opacity-90 hover:opacity-100 transition-opacity rounded-sm border border-zinc-200 dark:border-zinc-900" 
      title="NixOS"
    />
    <img 
      src="/buttons/miku.gif" 
      width="88" 
      height="31" 
      alt="Hatsune Miku" 
      loading="lazy"
      decoding="async"
      class="opacity-90 hover:opacity-100 transition-opacity rounded-sm border border-zinc-200 dark:border-zinc-900" 
      title="Hatsune Miku"
    />
 
    <img 
      src="/buttons/kawaiibutton.gif" 
      width="88" 
      height="31" 
      alt="Kawaii Button" 
      loading="lazy"
      decoding="async"
      class="opacity-90 hover:opacity-100 transition-opacity rounded-sm border border-zinc-200 dark:border-zinc-900" 
      title="Kawaii Button"
    />
    <img 
      src="/buttons/pikachu.gif" 
      width="88" 
      height="31" 
      alt="Pikachu" 
      loading="lazy"
      decoding="async"
      class="opacity-90 hover:opacity-100 transition-opacity rounded-sm border border-zinc-200 dark:border-zinc-900" 
      title="Pikachu"
    />
    <img 
      src="/buttons/fingerofgod.gif" 
      width="88" 
      height="31" 
      alt="Finger of God" 
      loading="lazy"
      decoding="async"
      class="opacity-90 hover:opacity-100 transition-opacity rounded-sm border border-zinc-200 dark:border-zinc-900" 
      title="Finger of God"
    />
  </div>
</footer>
