<nav class="w-full border-b border-zinc-900 bg-zinc-950/80 backdrop-blur-md sticky top-0 z-50">
  <div class="max-w-2xl mx-auto px-6 h-14 flex items-center justify-between font-mono text-xs tracking-widest uppercase">
    <div class="flex items-center gap-6">
      <a href="/" class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors duration-200 lowercase">cd</a>
      <a href="/blog" class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors duration-200">BLOG</a>
      <a href="/projects" class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors duration-200">PROJECTS</a>
      <a href="/oss" class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors duration-200">OSS</a>
    </div>
    
    <!-- Light / Dark toggle -->
    <button 
      id="theme-toggle" 
      class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors duration-200 cursor-pointer font-mono text-xs tracking-widest"
      title="Toggle Theme"
      aria-label="Toggle Theme"
    >
      <span class="theme-label-dark">LIGHT</span>
      <span class="theme-label-light hidden">DARK</span>
    </button>
  </div>
</nav>

<script>
  function setupTheme() {
    const toggleBtn = document.getElementById("theme-toggle");
    const darkLabel = document.querySelector(".theme-label-dark");
    const lightLabel = document.querySelector(".theme-label-light");

    const getTheme = () => {
      if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
        return localStorage.getItem("theme");
      }
      return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    };

    const setTheme = (theme: string) => {
      if (theme === "light") {
        document.documentElement.classList.add("light");
        document.documentElement.classList.remove("dark");
        darkLabel?.classList.add("hidden");
        lightLabel?.classList.remove("hidden");
      } else {
        document.documentElement.classList.add("dark");
        document.documentElement.classList.remove("light");
        darkLabel?.classList.remove("hidden");
        lightLabel?.classList.add("hidden");
      }
      localStorage.setItem("theme", theme);
    };

    // Initialize labels
    setTheme(getTheme() || "dark");

    toggleBtn?.addEventListener("click", () => {
      const isLight = document.documentElement.classList.contains("light");
      setTheme(isLight ? "dark" : "light");
    });
  }

  // Run on load
  setupTheme();
  // Support View Transitions swap if applicable
  document.addEventListener("astro:after-swap", setupTheme);
</script>
